{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "QuickShell Settings",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "language": {
      "type": "string",
      "enum": [
        "en",
        "es"
      ],
      "description": "UI language"
    },
    "framework": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "frameMode": {
          "type": "boolean",
          "description": "Enables frame mode for the bar"
        },
        "inactiveBarSize": {
          "type": "integer",
          "minimum": 1,
          "description": "Bar size when inactive (px)"
        },
        "activeBarSize": {
          "type": "integer",
          "minimum": 1,
          "description": "Bar size when active/expanded (px)"
        },
        "drawerWidth": {
          "type": "integer",
          "minimum": 1,
          "description": "Drawer panel width (px)"
        },
        "drawerHeight": {
          "type": "integer",
          "minimum": 1,
          "description": "Panel popup height (px)"
        },
        "overlay": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "width": {
              "type": "integer",
              "minimum": 1,
              "description": "Overlay panel width (px)"
            },
            "position": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "side": {
                  "type": "string",
                  "enum": [
                    "top",
                    "bottom",
                    "left",
                    "right"
                  ],
                  "description": "Screen edge where overlays appear"
                },
                "align": {
                  "type": "string",
                  "enum": [
                    "start",
                    "center",
                    "end"
                  ],
                  "description": "Alignment along the side edge"
                }
              }
            },
            "popupTimeout": {
              "type": "integer",
              "minimum": 0,
              "description": "Milliseconds before an overlay popup auto-dismisses"
            },
            "maxVisible": {
              "type": "integer",
              "minimum": 1,
              "description": "Maximum number of overlays visible simultaneously"
            }
          }
        },
        "bars": {
          "type": "object",
          "description": "Bar positions and their module layout",
          "additionalProperties": false,
          "properties": {
            "top": {
              "$ref": "#/$defs/horizontalBar"
            },
            "bottom": {
              "$ref": "#/$defs/horizontalBar"
            },
            "left": {
              "$ref": "#/$defs/verticalBar"
            },
            "right": {
              "$ref": "#/$defs/verticalBar"
            }
          }
        },
        "corners": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "topLeft": {
              "$ref": "#/$defs/moduleItem"
            },
            "topRight": {
              "$ref": "#/$defs/moduleItem"
            },
            "bottomLeft": {
              "$ref": "#/$defs/moduleItem"
            },
            "bottomRight": {
              "$ref": "#/$defs/moduleItem"
            }
          }
        }
      }
    },
    "background": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "wallpaperPath": {
          "type": "string",
          "description": "Absolute path to the wallpaper image"
        }
      }
    },
    "theme": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "enum": [
            "rose-pine-main",
            "rose-pine-moon",
            "rose-pine-dawn"
          ],
          "description": "Theme name"
        },
        "font": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "family": {
              "type": "string",
              "description": "Font family name"
            },
            "size": {
              "type": "integer",
              "minimum": 1,
              "description": "Font size (px)"
            }
          }
        },
        "spacing": {
          "type": "integer",
          "minimum": 0,
          "description": "Base spacing for padding, margins, and gaps (px)"
        },
        "radius": {
          "type": "integer",
          "minimum": 0,
          "description": "Border radius for rounded corners (px)"
        },
        "icon": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "size": {
              "type": "integer",
              "minimum": 1,
              "description": "Default icon size (px)"
            },
            "strokeWidth": {
              "type": "number",
              "minimum": 0,
              "description": "Default stroke width for Lucide icons (default: 2)"
            }
          }
        },
        "accent": {
          "$ref": "#/$defs/accentColor",
          "description": "Default accent color token applied to all chips that don't specify their own"
        },
        "variant": {
          "$ref": "#/$defs/moduleVariant",
          "description": "Default visual variant applied to all chips that don't specify their own"
        }
      }
    }
  },
  "$defs": {
    "moduleId": {
      "type": "string",
      "enum": [
        "battery",
        "brightness",
        "clock",
        "network",
        "notifications",
        "volume",
        "workspaces"
      ],
      "description": "Module identifier"
    },
    "accentColor": {
      "type": "string",
      "enum": [
        "accent1",
        "accent2",
        "accent3",
        "accent4",
        "accent5",
        "accent6",
        "base",
        "surface",
        "overlay",
        "text",
        "subtle",
        "muted",
        "success",
        "warning",
        "error",
        "info",
        "highlightLow",
        "highlightMed",
        "highlightHigh"
      ],
      "description": "Theme color token"
    },
    "moduleVariant": {
      "type": "string",
      "enum": [
        "filled",
        "default"
      ],
      "description": "Module visual variant"
    },
    "moduleMode": {
      "type": "string",
      "enum": [
        "panel",
        "window"
      ],
      "description": "How the module's content opens — panel/drawer or floating window"
    },
    "moduleItem": {
      "oneOf": [
        {
          "$ref": "#/$defs/moduleId"
        },
        {
          "type": "object",
          "required": [
            "id"
          ],
          "additionalProperties": false,
          "properties": {
            "id": {
              "$ref": "#/$defs/moduleId"
            },
            "accent": {
              "$ref": "#/$defs/accentColor"
            },
            "variant": {
              "$ref": "#/$defs/moduleVariant"
            },
            "mode": {
              "$ref": "#/$defs/moduleMode"
            }
          }
        }
      ]
    },
    "moduleList": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/moduleItem"
      }
    },
    "horizontalBar": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "left": {
          "$ref": "#/$defs/moduleList"
        },
        "center": {
          "$ref": "#/$defs/moduleList"
        },
        "right": {
          "$ref": "#/$defs/moduleList"
        }
      }
    },
    "verticalBar": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "top": {
          "$ref": "#/$defs/moduleList"
        },
        "center": {
          "$ref": "#/$defs/moduleList"
        },
        "bottom": {
          "$ref": "#/$defs/moduleList"
        }
      }
    }
  }
}